<!DOCTYPE html>
<%- include('../partials/head') %>

<body class="min-h-screen flex flex-col bg-cover bg-center"
style="background-image: url('/images/jonathan-francisca-BpbkLACP64M-unsplash.jpg')">

    <main class="grow flex items-center justify-center">

        <div class="w-full max-w-md bg-white/90 backdrop-blur-sm shadow-xl rounded-xl p-8">

            <h2 class="text-center text-xl font-semibold uppercase">
            OTP Verification Code
            </h2>

            <p class="text-center text-gray-600 text-sm mt-2">
            A 6-digit code has been sent to your email
            </p>

            <form action="/api/admins/forgotten-password-otp" method="POST" id="form" class="mt-6 space-y-6" novalidate>

                <div class="flex justify-center gap-2">

                    <input type="text" name="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]*"
                    class="otp-input w-12 h-12 text-center text-lg border border-gray-300 rounded-md focus:ring-2 focus:ring-cyan-600 outline-none"/>

                    <input type="text" name="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]*"
                    class="otp-input w-12 h-12 text-center text-lg border border-gray-300 rounded-md focus:ring-2 focus:ring-cyan-600 outline-none"/>

                    <input type="text" name="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]*"
                    class="otp-input w-12 h-12 text-center text-lg border border-gray-300 rounded-md focus:ring-2 focus:ring-cyan-600 outline-none"/>

                    <input type="text" name="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]*"
                    class="otp-input w-12 h-12 text-center text-lg border border-gray-300 rounded-md focus:ring-2 focus:ring-cyan-600 outline-none"/>

                    <input type="text" name="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]*"
                    class="otp-input w-12 h-12 text-center text-lg border border-gray-300 rounded-md focus:ring-2 focus:ring-cyan-600 outline-none"/>

                    <input type="text" name="otp-box" maxlength="1" inputmode="numeric" pattern="[0-9]*"
                    class="otp-input w-12 h-12 text-center text-lg border border-gray-300 rounded-md focus:ring-2 focus:ring-cyan-600 outline-none"/>

                </div>

                <input
                type="submit"
                value="Verify Code"
                class="w-full py-3 bg-cyan-700 text-white rounded-full hover:bg-cyan-800 cursor-pointer outline-none"
                />

                <a
                href="/admin/resend-otp"
                class="block text-center py-3 bg-gray-200 rounded-full hover:bg-gray-300 outline-none">
                Resend Code
                </a>

            </form>

        </div>

    </main>

    <%- include('../partials/foot') %>

    <script id="toast-data" type="application/json">
        <%- JSON.stringify({
            error: error || [],
            success: success || []
        }) %>
    </script>

    <script src="/javascript/admin/otp.js"></script>
    <script src="/javascript/toast.js"></script>

</body>
</html>