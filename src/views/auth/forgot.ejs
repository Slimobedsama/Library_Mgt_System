
<div class="w-full max-w-md bg-white/90 backdrop-blur-sm shadow-xl rounded-xl p-8">

    <h2 class="text-center text-xl font-semibold uppercase mb-6">
    Forgot Password
    </h2>

    <form action="/api/admins/forgotten-password" method="POST" class="space-y-4" novalidate>

        <input
        type="email"
        name="email"
        placeholder="Email"
        value="<%= email %>"
        required
        class="w-full px-4 py-3 border border-gray-300 rounded-md focus:ring-2 focus:ring-cyan-600 outline-none"
        />

        <input
        type="submit"
        value="Continue"
        class="w-full py-3 bg-cyan-700 text-white rounded-full hover:bg-cyan-800 cursor-pointer"
        />

        <a
        href="/admin/login"
        class="block text-center py-3 bg-gray-200 rounded-full hover:bg-gray-300">
        Return to Login
        </a>

    </form>

</div>